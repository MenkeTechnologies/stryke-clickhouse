## t/test_clickhouse.stk — assertion tests for the stryke `Clickhouse` package.
##
## Needs the cdylib loaded (`s pkg install -g .`) so `use Clickhouse` dlopens
## `lib/libstryke_clickhouse.{dylib,so}`. The data-side asserts also need a
## live ClickHouse at `$CLICKHOUSE_URL` (or `127.0.0.1:8123`); they short-circuit
## when ping fails so CI without a server exits clean on the connection-free asserts.

use Clickhouse

# ── permission-free: cdylib reachable ───────────────────────────────
assert_ok Clickhouse::version(), "Clickhouse::version returns truthy (cdylib loaded)"
assert_eq Clickhouse::escape("x'y"), "x\\'y", "escape builder"

# ── liveness probe ──────────────────────────────────────────────────
var %conn
$conn{url} = $ENV{CLICKHOUSE_URL} if defined $ENV{CLICKHOUSE_URL}
val $alive = eval { Clickhouse::ping(%conn) }

if ($alive) {
    val $tbl = "stryke_test_$$"

    # 1. create a MergeTree table
    Clickhouse::create_table(
        $tbl,
        columns  => "id UInt64, name String",
        order_by => "id",
        %conn,
    )
    assert_ok Clickhouse::table_exists($tbl, %conn), "table created"

    # 2. bulk insert
    val $n = Clickhouse::insert($tbl, [
        { id => 1, name => "alpha" },
        { id => 2, name => "beta"  },
        { id => 3, name => "gamma" },
    ], %conn)
    assert_eq $n, 3, "insert reports 3 rows"

    # 3. count
    assert_eq Clickhouse::count($tbl, %conn), 3, "count is 3"

    # 4. query_value scalar
    val $uniq = Clickhouse::query_value("SELECT uniqExact(id) FROM $tbl", %conn)
    assert_eq $uniq, 3, "uniqExact(id) = 3"

    # 5. query_rows with group by
    val @rows = Clickhouse::query_rows("SELECT name FROM $tbl ORDER BY id", %conn)
    assert_eq len(@rows), 3, "query_rows returns 3 rows"
    assert_eq $rows[0]{name}, "alpha", "first row name"

    # 6. query_row
    val $row = Clickhouse::query_row("SELECT id, name FROM $tbl WHERE id = 2", %conn)
    assert_eq $row->{name}, "beta", "query_row by id"

    # 7. describe
    val @cols = Clickhouse::describe($tbl, %conn)
    assert_eq $cols[0]{name}, "id", "describe first column"

    # 8. table appears in tables list
    val @tbls = Clickhouse::tables(%conn)
    assert_ok len(@tbls) >= 1, "tables list non-empty"

    # 9. database_exists for the default database
    assert_ok Clickhouse::database_exists("default", %conn), "default database exists"
    assert_eq Clickhouse::database_exists("no_such_db_$$", %conn), false, "missing database absent"

    # 10. columns metadata richer than describe
    val @meta = Clickhouse::columns($tbl, %conn)
    assert_eq len(@meta), 2, "columns returns 2 columns"
    assert_eq $meta[0]{name}, "id", "columns first name"
    assert_eq $meta[0]{type}, "UInt64", "columns first type"

    # 11. disk_usage aggregate over active parts
    val $du = Clickhouse::disk_usage($tbl, %conn)
    assert_eq $du->{rows}, 3, "disk_usage rows = 3"

    # 12. add_column then verify, then drop_column
    Clickhouse::add_column($tbl, "score", "Float64", default => "0", %conn)
    val @meta2 = Clickhouse::columns($tbl, %conn)
    assert_eq len(@meta2), 3, "add_column added a column"
    Clickhouse::drop_column($tbl, "score", %conn)
    val @meta3 = Clickhouse::columns($tbl, %conn)
    assert_eq len(@meta3), 2, "drop_column removed the column"

    # 13. lightweight delete
    Clickhouse::delete_where($tbl, "id = 2", %conn)
    Clickhouse::optimize($tbl, final => true, %conn)
    assert_eq Clickhouse::count($tbl, %conn), 2, "delete_where removed one row"

    # 14. mutations + processes return arrays (no rows asserted, just shape)
    val @muts = Clickhouse::mutations($tbl, %conn)
    assert_ok ref(\@muts) eq "ARRAY", "mutations returns a list"
    val @procs = Clickhouse::processes(%conn)
    assert_ok ref(\@procs) eq "ARRAY", "processes returns a list"

    # cleanup
    Clickhouse::drop_table($tbl, %conn)
    assert_eq Clickhouse::table_exists($tbl, %conn), false, "table dropped"
}

test_run
